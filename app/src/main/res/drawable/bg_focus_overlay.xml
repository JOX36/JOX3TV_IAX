<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Solo se ve cuando el control remoto/D-pad selecciona este elemento.
         En celular (modo táctil) Android nunca activa state_focused así,
         por lo que esto es invisible al tocar con el dedo.
         Incluye un oscurecido de fondo para que el contorno se note
         siempre, sin importar el color de lo que esté debajo. -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Oscurece levemente el fondo para garantizar contraste -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#40000000" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
            <!-- Resplandor exterior tenue -->
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="7dp" android:color="#66FF1744" />
                    <corners android:radius="10dp" />
                    <solid android:color="@android:color/transparent" />
                </shape>
            </item>
            <!-- Contorno neón nítido -->
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="3dp" android:color="#FF1744" />
                    <corners android:radius="10dp" />
                    <solid android:color="@android:color/transparent" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
